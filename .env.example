# ═══════════════════════════════════════════════════════════════════
# ChannelZero — Environment Config Template
# Copy to .env and fill in your values. Never commit .env itself.
# ═══════════════════════════════════════════════════════════════════

# ── Vercel Postgres (Neon) ──────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://user:pass@host-unpooled/dbname?sslmode=require
PGHOST=your-neon-pooler-host
PGHOST_UNPOOLED=your-neon-direct-host
PGUSER=your_db_user
PGDATABASE=your_db_name
PGPASSWORD=your_db_password

# ── FastAPI Server ──────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SERVER_ENCRYPTION_KEY=
CORS_ORIGINS=http://localhost:5173,https://channelzero.vercel.app

# ── Spotify OAuth ──────────────────────────────────────────────
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://localhost:8000/api/spotify/callback

# ── Google OAuth ──────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback
# GCAL_REDIRECT_URI=http://localhost:8000/api/gcal/callback

# ── X (Twitter) OAuth ────────────────────────────────────────
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_REDIRECT_URI=http://localhost:5173/auth/x/callback

# ── Strava OAuth ─────────────────────────────────────────────
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# STRAVA_REDIRECT_URI=http://localhost:5173/auth/strava/callback

# ── Steam (OpenID 2.0 + Web API) ─────────────────────────────
# Free key from https://steamcommunity.com/dev/apikey
# STEAM_API_KEY=
# STEAM_REDIRECT_URI=http://localhost:8000/api/steam/callback

# ── Letterboxd API ────────────────────────────────────────────
# Apply at https://letterboxd.com/api-beta/
# LETTERBOXD_API_KEY=
# LETTERBOXD_API_SECRET=
# LETTERBOXD_REDIRECT_URI=http://localhost:8000/api/letterboxd/callback

# ── Pinecone ─────────────────────────────────────────────────
# PINECONE_API_KEY=
# PINECONE_INDEX=channelzero

# ── Embeddings (server-level, NOT per-user) ───────────────────
# OPENAI_EMBED_KEY=

# ── Vite (frontend) ────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
